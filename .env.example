# === Critical (required) ===
SEED_PHRASE="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# === RPC ===
TRON_RPC_URL=https://api.trongrid.io
BSC_RPC_URL=https://bsc-dataseed.binance.org

# === Economics ===
MIN_USDT_AMOUNT=10.0
PROFIT_FEE_USD=1.0

# === Rebalance ===
REBALANCE_THRESHOLD=500.0

# === Storage ===
DB_PATH=kum4_data

# === Contracts ===
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
BSC_USDT_CONTRACT=0x55d398326f99059ff775485246999027b3197955

# === Network ===
BTC_NETWORK=mainnet
MEMPOOL_URL=https://mempool.space

# === Web ===
WEB_HOST=127.0.0.1
NODE_PORT=8080
NODE_ID=kum4-default
NODE_VERSION=0.1.0

# === Mesh / DHT ===
# Each node auto-derives PeerId from SEED_PHRASE
# libp2p Kademlia listens on NODE_PORT+1
# Nodes discover each other via DHT, no central registry

# === Tor / Clearnet ===
# TOR_ENABLED=true  → Tor SOCKS5 + DHT (mesh mode)
# TOR_ENABLED=false → direct HTTP, no DHT (standalone mode)
TOR_ENABLED=false
TOR_PROXY=socks5://127.0.0.1:9050

# === Testnet (uncomment for testing) ===
# BTC_NETWORK=testnet
# MEMPOOL_URL=https://mempool.space/testnet
# TRON_RPC_URL=https://api.nileex.io
# TRON_USDT_CONTRACT=TXLAq63qCJg1D9HULiNvzsA4vgbGZW1uBc
# BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# BSC_USDT_CONTRACT=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
